{
  "Version": "2012-10-17",
  "Statement": [{
    "Effect": "Allow",
    "Principal": {"Federated": "arn:aws:iam::791860731989:oidc-provider/token.actions.githubusercontent.com"},
    "Action": "sts:AssumeRoleWithWebIdentity",
    "Condition": {
      "StringEquals": {"token.actions.githubusercontent.com:aud": "sts.amazonaws.com"},
      "ForAnyValue:StringLike": {"token.actions.githubusercontent.com:sub": [
        "repo:drolu-cmyk/sozorock-health:environment:staging",
        "repo:drolu-cmyk/sozorock-health:environment:production"
      ]}
    }
  }]
}
