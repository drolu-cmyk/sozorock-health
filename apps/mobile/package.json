{
  "name": "@sozorock/mobile",
  "private": true,
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "check:config": "expo config --type public",
    "export:android": "expo export --platform android",
    "export:ios": "expo export --platform ios",
    "release:doctor": "npx --yes expo-doctor@1.20.0",
    "release:validate": "node scripts/validate-release-env.mjs",
    "release:validate:submit": "node scripts/validate-release-env.mjs --submit",
    "release:build": "npx --yes eas-cli@20.5.1 build --platform all --profile production --non-interactive",
    "release:submit:internal": "npx --yes eas-cli@20.5.1 submit --platform ios --profile production --latest --non-interactive && npx --yes eas-cli@20.5.1 submit --platform android --profile internal --latest --non-interactive",
    "release:submit:production": "npx --yes eas-cli@20.5.1 submit --platform ios --profile production --latest --non-interactive && npx --yes eas-cli@20.5.1 submit --platform android --profile production --latest --non-interactive",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native/virtualized-lists": "0.86.0",
    "babel-preset-expo": "57.0.2",
    "expo": "57.0.4",
    "expo-localization": "57.0.0",
    "expo-speech": "57.0.0",
    "expo-speech-recognition": "^56.0.1",
    "expo-splash-screen": "~57.0.2",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "devDependencies": {
    "@types/react": "19.2.7",
    "typescript": "~6.0.3"
  }
}
