{
  "expo": {
    "name": "SozoRock Health",
    "description": "Non-clinical health readiness, digital navigation, Health Equity Hubs, Voice Access, and provider-led pathway preparation from The SozoRock Foundation, Inc.",
    "slug": "sozorock-health",
    "scheme": "sozorockhealth",
    "version": "1.0.0",
    "icon": "./assets/app-icon.png",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F8F5EE",
    "primaryColor": "#385847",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.sozorockfoundation.health",
      "requireFullScreen": false,
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleLocalizations": ["en", "es"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "org.sozorockfoundation.health",
      "predictiveBackGestureEnabled": true,
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#083D68"
      }
    },
    "plugins": [
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/sozorock-wordmark.png",
          "imageWidth": 260,
          "resizeMode": "contain",
          "backgroundColor": "#F8F5EE"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow SozoRock Health to use the microphone when you choose voice input.",
          "speechRecognitionPermission": "Allow SozoRock Health to turn your spoken access request into text.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox",
            "com.google.android.tts"
          ]
        }
      ]
    ]
  }
}
