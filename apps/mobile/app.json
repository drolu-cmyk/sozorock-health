{
  "expo": {
    "name": "SozoRock Health",
    "slug": "sozorock-health",
    "version": "0.1.0",
    "icon": "./assets/app-icon.png",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F8F5EE",
    "primaryColor": "#385847",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.sozorockfoundation.health",
      "requireFullScreen": false,
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleLocalizations": ["en", "es"]
      }
    },
    "android": {
      "package": "org.sozorockfoundation.health",
      "predictiveBackGestureEnabled": true,
      "versionCode": 1
    },
    "plugins": ["expo-localization"]
  }
}
